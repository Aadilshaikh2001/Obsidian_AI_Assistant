# Environment configuration template for Cornelius-Ollama
# Copy this file to .env and fill in your values

# Ollama Configuration
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen3-coder-next:cloud
OLLAMA_TIMEOUT=120

# Vault Configuration
VAULT_PATH=D:\Obsidian\Obsidian_AI_Assistant
VAULT_INBOX=inbox
VAULT_TOP_K=3
VAULT_MIN_SCORE=0.1

# Session Configuration
MAX_HISTORY_MESSAGES=20
STREAM_TOKENS=true

# Voice Configuration (Whisper)
VOICE_MODEL=base
VOICE_LANGUAGE=en
